# klang.hk.cn 环境变量模板
#
# 使用方式：
#   1. cp overlay/.env.local.example overlay/.env.local
#   2. 编辑 overlay/.env.local（此文件不会提交 git）
#   3. npm run overlay   # 同步到 apps/web/.env.local
#
# 注意：不要直接改 apps/web/.env.local，升级/reset 会被覆盖。

# ── 主题 ──────────────────────────────────────────
# 对应 overlay/theme/ 下的目录名，当前定制主题为 klang
NEXT_PUBLIC_THEME=klang

# ── 站点 ──────────────────────────────────────────
# 用于 SEO、sitemap、JSON-LD（theme/klang/site.ts 也会读取）
NEXT_PUBLIC_SITE_URL=https://klang.hk.cn

# ── EventStore 数据库名 ───────────────────────────
# config.ts 会在未设置 WS URL 时拼接到连接地址
EVENTSTORE_DB_NAME=klanghkcn

# ── EventStore WebSocket ──────────────────────────
# 服务端 SSR / API 使用（不要加 NEXT_PUBLIC_ 前缀）
EVENTSTORE_WS_URL=ws://127.0.0.1:8080/?dbName=klanghkcn

# 浏览器端使用（登录、上传等，必须 NEXT_PUBLIC_ 前缀）
NEXT_PUBLIC_EVENTSTORE_WS_URL=ws://127.0.0.1:8080/?dbName=klanghkcn

# ── 文件上传 ──────────────────────────────────────
UPLOAD_BASE_URL=http://127.0.0.1:8081/uploads/
